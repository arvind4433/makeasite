# ==========================================
# Frontend Environment Variables (Vite)
# ==========================================

# API Base URL
VITE_API_BASE_URL="http://localhost:5000"
VITE_API_URL=http://localhost:5000/api

# App Branding
VITE_APP_NAME=MakeASite
VITE_APP_TAGLINE=Professional Web Development Agency

# Feature Flags
VITE_ENABLE_ANALYTICS=false

# OAuth - Google (must match backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=627807452362-6l3f6bg3vu6jitvfqr42u0ceet80frbm.apps.googleusercontent.com

# OAuth - Facebook (uncomment when FACEBOOK_APP_ID is known)
# VITE_FACEBOOK_APP_ID=your_facebook_app_id
