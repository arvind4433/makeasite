# ==========================================
# Frontend Environment Variables (Vite)
# ==========================================

# API Base URL
VITE_API_BASE_URL=https://makeasite.online
VITE_API_URL=https://makeasite.online

# App Branding
VITE_APP_NAME=WebDevPro
VITE_APP_TAGLINE=Professional Web Development Agency

# Feature Flags
VITE_ENABLE_ANALYTICS=false

# OAuth - Google (must match backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=290550404176-824ii14mj5k8chn0s8mun9s6rggkcols.apps.googleusercontent.com

# OAuth - Facebook (uncomment when FACEBOOK_APP_ID is known)
# VITE_FACEBOOK_APP_ID=your_facebook_app_id
